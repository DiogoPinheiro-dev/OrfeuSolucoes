generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String  @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  nome      String? @map("Nome")
  login     String? @map("Login")
  email     String  @unique(map: "UX_Usuarios_Email") @map("Email")
  senhaHash String  @map("Senha")
  grupoId   Int?    @map("GrupoId")
  deveAlterarSenha Boolean @default(false) @map("DeveAlterarSenha")

  empresas EmpresaUsuario[]
  grupo    GrupoUsuario? @relation(fields: [grupoId], references: [id])

  @@map("Usuarios")
}

model GrupoUsuario {
  id              Int     @id @default(autoincrement()) @map("Id")
  nome            String  @unique(map: "UX_GruposUsuarios_Nome") @map("Nome")
  descricao       String? @map("Descricao")
  acessoEcommerce Boolean @default(false) @map("AcessoEcommerce")
  acessoProjetos  Boolean @default(false) @map("AcessoProjetos")
  acessoHoras     Boolean @default(false) @map("AcessoHoras")
  acessoConfigurador Boolean @default(false) @map("AcessoConfigurador")
  podeVisualizar Boolean @default(true) @map("PodeVisualizar")
  podeIncluir    Boolean @default(false) @map("PodeIncluir")
  podeAlterar    Boolean @default(false) @map("PodeAlterar")
  podeExcluir    Boolean @default(false) @map("PodeExcluir")

  usuarios Usuario[]

  @@map("GruposUsuarios")
}

model Servico {
  id        Int      @id @default(autoincrement()) @map("Id")
  titulo    String?  @map("Titulo")
  descricao String?  @map("Descricao")
  valor     Decimal? @db.Decimal(18, 2) @map("Valor")
  desconto  Decimal? @db.Decimal(18, 2) @map("Desconto")
  vendas    Int?     @map("Vendas")

  @@map("Servicos")
}

model Empresa {
  id              Int      @id @default(autoincrement()) @map("Id")
  nome            String?  @map("Nome")
  acessoEcommerce Boolean  @default(false) @map("AcessoEcommerce")
  acessoProjetos  Boolean  @default(false) @map("AcessoProjetos")
  acessoHoras     Boolean  @default(false) @map("AcessoHoras")
  // cnpj        String?  @map("CNPJ")
  // endereco    String?  @map("Endereco")
  // telefone    String?  @map("Telefone")
  // email       String?  @map("Email")
  // descricao   String?  @map("Descricao")

  usuarios EmpresaUsuario[]

  @@map("Empresas")
}

model EmpresaUsuario {
  id         Int      @id @default(autoincrement()) @map("Id")
  empresaId  Int      @map("EmpresaId")
  usuarioId  String   @db.UniqueIdentifier @map("UsuarioId")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([empresaId, usuarioId], map: "UX_EmpresaUsuarios_EmpresaId_UsuarioId")
  @@map("EmpresaUsuarios")
}
