generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String  @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  nome      String? @map("Nome")
  login     String? @map("Login")
  email     String  @unique(map: "UX_Usuarios_Email") @map("Email")
  senhaHash String  @map("Senha")
  grupoId   Int?    @map("GrupoId")
  deveAlterarSenha Boolean @default(false) @map("DeveAlterarSenha")
  padraoSistema Boolean @default(false) @map("PadraoSistema")

  empresas EmpresaUsuario[]
  grupo    GrupoUsuario? @relation(fields: [grupoId], references: [id])
  chamadosSolicitados Chamado[] @relation("ChamadoSolicitante")
  chamadosResponsavel Chamado[] @relation("ChamadoResponsavel")
  chamadosLiderAtendimento Chamado[] @relation("ChamadoLiderAtendimento")
  chamadosAcompanhando ChamadoAcompanhante[] @relation("ChamadoAcompanhanteUsuario")
  chamadosAcompanhantesAdicionados ChamadoAcompanhante[] @relation("ChamadoAcompanhanteAdicionadoPor")
  chamadoMensagens ChamadoMensagem[]
  chamadoHistoricos ChamadoHistorico[]
  chamadoResponsaveisConfigurados ChamadoResponsavel[]
  chamadoAnexos ChamadoAnexo[]
  chamadoNotificacoes ChamadoNotificacao[]
  googleEmailContasCriadas GoogleEmailConta[]
  projetosCriados Projeto[] @relation("ProjetoCriador")
  projetosResponsavel Projeto[] @relation("ProjetoResponsavel")
  projetosArquivados Projeto[] @relation("ProjetoArquivadoPor")
  projetosParticipacoes ProjetoMembro[]

  @@map("Usuarios")
}

model GrupoUsuario {
  id              Int     @id @default(autoincrement()) @map("Id")
  nome            String  @unique(map: "UX_GruposUsuarios_Nome") @map("Nome")
  descricao       String? @map("Descricao")
  acessoEcommerce Boolean @default(false) @map("AcessoEcommerce")
  acessoProjetos  Boolean @default(false) @map("AcessoProjetos")
  acessoHoras     Boolean @default(false) @map("AcessoHoras")
  acessoConfigurador Boolean @default(false) @map("AcessoConfigurador")
  padraoSistema Boolean @default(false) @map("PadraoSistema")
  podeVisualizar Boolean @default(true) @map("PodeVisualizar")
  podeIncluir    Boolean @default(false) @map("PodeIncluir")
  podeAlterar    Boolean @default(false) @map("PodeAlterar")
  podeExcluir    Boolean @default(false) @map("PodeExcluir")

  usuarios Usuario[]
  solucoes GrupoSolucao[]
  funcionalidades GrupoFuncionalidade[]
  funcionalidadeAcoes GrupoFuncionalidadeAcao[]
  chamadosResponsavelGrupo Chamado[] @relation("ChamadoResponsavelGrupo")
  chamadoResponsaveisConfigurados ChamadoResponsavel[]

  @@map("GruposUsuarios")
}

model Servico {
  id        Int      @id @default(autoincrement()) @map("Id")
  titulo    String?  @map("Titulo")
  descricao String?  @map("Descricao")
  valor     Decimal? @db.Decimal(18, 2) @map("Valor")
  desconto  Decimal? @db.Decimal(18, 2) @map("Desconto")
  vendas    Int?     @map("Vendas")

  @@map("Servicos")
}

model Empresa {
  id              Int      @id @default(autoincrement()) @map("Id")
  nome            String?  @map("Nome")
  acessoEcommerce Boolean  @default(false) @map("AcessoEcommerce")
  acessoProjetos  Boolean  @default(false) @map("AcessoProjetos")
  acessoHoras     Boolean  @default(false) @map("AcessoHoras")
  padraoSistema   Boolean  @default(false) @map("PadraoSistema")
  // cnpj        String?  @map("CNPJ")
  // endereco    String?  @map("Endereco")
  // telefone    String?  @map("Telefone")
  // email       String?  @map("Email")
  // descricao   String?  @map("Descricao")

  usuarios EmpresaUsuario[]
  solucoes EmpresaSolucao[]
  funcionalidades EmpresaFuncionalidade[]
  chamados Chamado[]
  chamadoCategorias ChamadoCategoria[]
  chamadoMensagens ChamadoMensagem[]
  chamadoHistoricos ChamadoHistorico[]
  chamadoResponsaveisConfigurados ChamadoResponsavel[]
  chamadoSequencia ChamadoSequencia?
  chamadoAnexos ChamadoAnexo[]
  chamadoNotificacoes ChamadoNotificacao[]
  chamadoAcompanhantes ChamadoAcompanhante[]
  chamadoTipos ChamadoTipo[]
  chamadoPrioridades ChamadoPrioridade[]
  chamadoSlaRegras ChamadoSlaRegra[]
  googleEmailContas GoogleEmailConta[]
  projetos Projeto[]

  @@map("Empresas")
}

model Projeto {
  id               String    @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  empresaId        Int       @map("EmpresaId")
  chave            String    @db.NVarChar(10) @map("Chave")
  nome             String    @db.NVarChar(200) @map("Nome")
  objetivo         String?   @db.NVarChar(500) @map("Objetivo")
  descricao        String?   @map("Descricao")
  metodologia      String    @db.NVarChar(20) @map("Metodologia")
  situacao         String    @db.NVarChar(20) @map("Situacao")
  saude            String    @db.NVarChar(20) @map("Saude")
  inicioPrevistoEm DateTime? @db.Date @map("InicioPrevistoEm")
  fimPrevistoEm    DateTime? @db.Date @map("FimPrevistoEm")
  inicioRealEm     DateTime? @db.Date @map("InicioRealEm")
  fimRealEm        DateTime? @db.Date @map("FimRealEm")
  responsavelId    String    @db.UniqueIdentifier @map("ResponsavelId")
  criadoPorId      String    @db.UniqueIdentifier @map("CriadoPorId")
  arquivadoEm      DateTime? @map("ArquivadoEm")
  arquivadoPorId   String?   @db.UniqueIdentifier @map("ArquivadoPorId")
  criadoEm         DateTime  @default(now()) @map("CriadoEm")
  atualizadoEm     DateTime  @updatedAt @map("AtualizadoEm")

  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsavel  Usuario  @relation("ProjetoResponsavel", fields: [responsavelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  criadoPor    Usuario  @relation("ProjetoCriador", fields: [criadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  arquivadoPor Usuario? @relation("ProjetoArquivadoPor", fields: [arquivadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  membros      ProjetoMembro[]

  @@unique([empresaId, chave], map: "UX_Projetos_EmpresaId_Chave")
  @@index([empresaId, arquivadoEm], map: "IX_Projetos_EmpresaId_ArquivadoEm")
  @@index([empresaId, atualizadoEm], map: "IX_Projetos_EmpresaId_AtualizadoEm")
  @@index([empresaId, responsavelId], map: "IX_Projetos_EmpresaId_ResponsavelId")
  @@map("Projetos")
}

model ProjetoMembro {
  id         Int      @id @default(autoincrement()) @map("Id")
  projetoId  String   @db.UniqueIdentifier @map("ProjetoId")
  usuarioId  String   @db.UniqueIdentifier @map("UsuarioId")
  papel      String   @db.NVarChar(20) @map("Papel")
  incluidoEm DateTime @default(now()) @map("IncluidoEm")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projetoId, usuarioId], map: "UX_ProjetoMembros_ProjetoId_UsuarioId")
  @@index([usuarioId], map: "IX_ProjetoMembros_UsuarioId")
  @@map("ProjetoMembros")
}
model Solucao {
  id                  Int      @id @default(autoincrement()) @map("Id")
  slug                String   @unique(map: "UX_Solucoes_Slug") @map("Slug")
  nome                String   @map("Nome")
  descricao           String?  @map("Descricao")
  eyebrow             String?  @map("Eyebrow")
  ordem               Int      @default(0) @map("Ordem")
  ativo               Boolean  @default(true) @map("Ativo")
  exibirNoHub         Boolean  @default(true) @map("ExibirNoHub")
  somenteAdminSistema Boolean  @default(false) @map("SomenteAdminSistema")

  funcionalidades Funcionalidade[]
  grupos GrupoSolucao[]
  empresas EmpresaSolucao[]
  chamadoResponsavelSolucoes ChamadoResponsavelSolucao[]
  chamados Chamado[]


  @@map("Solucoes")
}

model Funcionalidade {
  id                  Int      @id @default(autoincrement()) @map("Id")
  solucaoId           Int      @map("SolucaoId")
  slug                String   @map("Slug")
  titulo              String   @map("Titulo")
  label               String?  @map("Label")
  descricao           String?  @map("Descricao")
  ordem               Int      @default(0) @map("Ordem")
  ativo               Boolean  @default(true) @map("Ativo")
  registryKey         String?  @map("RegistryKey")
  somenteAdminSistema Boolean  @default(false) @map("SomenteAdminSistema")

  solucao Solucao @relation(fields: [solucaoId], references: [id], onDelete: Cascade)
  grupos GrupoFuncionalidade[]
  empresas EmpresaFuncionalidade[]
  acoes FuncionalidadeAcao[]
  chamadoResponsavelFuncionalidades ChamadoResponsavelFuncionalidade[]
  chamados Chamado[]


  @@unique([solucaoId, slug], map: "UX_Funcionalidades_SolucaoId_Slug")
  @@map("Funcionalidades")
}

model GrupoSolucao {
  id        Int @id @default(autoincrement()) @map("Id")
  grupoId   Int @map("GrupoId")
  solucaoId Int @map("SolucaoId")

  grupo GrupoUsuario @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  solucao Solucao @relation(fields: [solucaoId], references: [id], onDelete: Cascade)

  @@unique([grupoId, solucaoId], map: "UX_GrupoSolucoes_GrupoId_SolucaoId")
  @@map("GrupoSolucoes")
}

model EmpresaSolucao {
  id        Int @id @default(autoincrement()) @map("Id")
  empresaId Int @map("EmpresaId")
  solucaoId Int @map("SolucaoId")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  solucao Solucao @relation(fields: [solucaoId], references: [id], onDelete: Cascade)

  @@unique([empresaId, solucaoId], map: "UX_EmpresaSolucoes_EmpresaId_SolucaoId")
  @@map("EmpresaSolucoes")
}

model FuncionalidadeAcao {
  id               Int     @id @default(autoincrement()) @map("Id")
  funcionalidadeId Int     @map("FuncionalidadeId")
  chave            String  @map("Chave")
  nome             String  @map("Nome")
  descricao        String? @map("Descricao")
  ordem            Int     @default(0) @map("Ordem")
  ativo            Boolean @default(true) @map("Ativo")
  acaoPadrao       Boolean @default(false) @map("AcaoPadrao")
  configuracao     String? @map("Configuracao")

  funcionalidade Funcionalidade @relation(fields: [funcionalidadeId], references: [id], onDelete: Cascade)
  grupos GrupoFuncionalidadeAcao[]

  @@unique([funcionalidadeId, chave], map: "UX_FuncionalidadeAcoes_FuncionalidadeId_Chave")
  @@map("FuncionalidadeAcoes")
}

model GrupoFuncionalidade {
  id               Int @id @default(autoincrement()) @map("Id")
  grupoId          Int @map("GrupoId")
  funcionalidadeId Int @map("FuncionalidadeId")
  podeVisualizar   Boolean @default(true) @map("PodeVisualizar")
  podeIncluir      Boolean @default(false) @map("PodeIncluir")
  podeAlterar      Boolean @default(false) @map("PodeAlterar")
  podeExcluir      Boolean @default(false) @map("PodeExcluir")

  grupo GrupoUsuario @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  funcionalidade Funcionalidade @relation(fields: [funcionalidadeId], references: [id], onDelete: Cascade)

  @@unique([grupoId, funcionalidadeId], map: "UX_GrupoFuncionalidades_GrupoId_FuncionalidadeId")
  @@map("GrupoFuncionalidades")
}

model GrupoFuncionalidadeAcao {
  id                    Int     @id @default(autoincrement()) @map("Id")
  grupoId               Int     @map("GrupoId")
  funcionalidadeAcaoId  Int     @map("FuncionalidadeAcaoId")
  permitido             Boolean @default(false) @map("Permitido")

  grupo GrupoUsuario @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  funcionalidadeAcao FuncionalidadeAcao @relation(fields: [funcionalidadeAcaoId], references: [id], onDelete: Cascade)

  @@unique([grupoId, funcionalidadeAcaoId], map: "UX_GrupoFuncionalidadeAcoes_GrupoId_FuncionalidadeAcaoId")
  @@map("GrupoFuncionalidadeAcoes")
}

model EmpresaFuncionalidade {
  id               Int @id @default(autoincrement()) @map("Id")
  empresaId         Int @map("EmpresaId")
  funcionalidadeId Int @map("FuncionalidadeId")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  funcionalidade Funcionalidade @relation(fields: [funcionalidadeId], references: [id], onDelete: Cascade)

  @@unique([empresaId, funcionalidadeId], map: "UX_EmpresaFuncionalidades_EmpresaId_FuncionalidadeId")
  @@map("EmpresaFuncionalidades")
}

model EmpresaUsuario {
  id         Int      @id @default(autoincrement()) @map("Id")
  empresaId  Int      @map("EmpresaId")
  usuarioId  String   @db.UniqueIdentifier @map("UsuarioId")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([empresaId, usuarioId], map: "UX_EmpresaUsuarios_EmpresaId_UsuarioId")
  @@map("EmpresaUsuarios")
}

model Chamado {
  id                 String   @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  numero             Int      @map("Numero")
  empresaId          Int      @map("EmpresaId")
  solicitanteId      String   @db.UniqueIdentifier @map("SolicitanteId")
  responsavelId      String?  @db.UniqueIdentifier @map("ResponsavelId")
  responsavelGrupoId Int?     @map("ResponsavelGrupoId")
  liderAtendimentoId String?  @db.UniqueIdentifier @map("LiderAtendimentoId")
  atendimentoAssumidoEm DateTime? @map("AtendimentoAssumidoEm")
  categoriaId        Int?     @map("CategoriaId")
  solucaoId          Int?     @map("SolucaoId")
  funcionalidadeId   Int?     @map("FuncionalidadeId")
  titulo             String   @map("Titulo")
  descricao          String   @map("Descricao")
  tipoId             Int      @map("TipoId")
  prioridadeId       Int      @map("PrioridadeId")
  slaRegraId         Int?     @map("SlaRegraId")
  status             String   @default("ABERTO") @map("Status")
  criadoEm           DateTime @default(now()) @map("CriadoEm")
  atualizadoEm       DateTime @updatedAt @map("AtualizadoEm")
  primeiraRespostaEm DateTime? @map("PrimeiraRespostaEm")
  primeiraRespostaLimiteEm DateTime? @map("PrimeiraRespostaLimiteEm")
  resolvidoEm        DateTime? @map("ResolvidoEm")
  resolucaoLimiteEm  DateTime? @map("ResolucaoLimiteEm")
  slaPausadoEm       DateTime? @map("SlaPausadoEm")
  slaTempoPausadoMinutos Int   @default(0) @map("SlaTempoPausadoMinutos")
  slaStatus          String   @default("SEM_SLA") @map("SlaStatus")
  encerradoEm        DateTime? @map("EncerradoEm")
  versao             Int      @default(1) @map("Versao")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  solicitante Usuario @relation("ChamadoSolicitante", fields: [solicitanteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsavel Usuario? @relation("ChamadoResponsavel", fields: [responsavelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsavelGrupo GrupoUsuario? @relation("ChamadoResponsavelGrupo", fields: [responsavelGrupoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  liderAtendimento Usuario? @relation("ChamadoLiderAtendimento", fields: [liderAtendimentoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoria ChamadoCategoria? @relation(fields: [categoriaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  solucao Solucao? @relation(fields: [solucaoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  funcionalidade Funcionalidade? @relation(fields: [funcionalidadeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tipoConfiguracao ChamadoTipo @relation(fields: [tipoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prioridadeConfiguracao ChamadoPrioridade @relation(fields: [prioridadeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  slaRegra ChamadoSlaRegra? @relation(fields: [slaRegraId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notificacoes ChamadoNotificacao[]
  mensagens ChamadoMensagem[]
  historico ChamadoHistorico[]
  anexos ChamadoAnexo[]
  acompanhantes ChamadoAcompanhante[]

  @@unique([empresaId, numero], map: "UX_Chamados_EmpresaId_Numero")
  @@index([empresaId, status], map: "IX_Chamados_EmpresaId_Status")
  @@index([empresaId, responsavelId], map: "IX_Chamados_EmpresaId_ResponsavelId")
  @@index([empresaId, responsavelGrupoId], map: "IX_Chamados_EmpresaId_ResponsavelGrupoId")
  @@index([empresaId, liderAtendimentoId], map: "IX_Chamados_EmpresaId_LiderAtendimentoId")
  @@index([empresaId, solicitanteId], map: "IX_Chamados_EmpresaId_SolicitanteId")
  @@index([empresaId, tipoId], map: "IX_Chamados_EmpresaId_TipoId")
  @@index([empresaId, prioridadeId], map: "IX_Chamados_EmpresaId_PrioridadeId")
  @@index([empresaId, solucaoId], map: "IX_Chamados_EmpresaId_SolucaoId")
  @@index([empresaId, funcionalidadeId], map: "IX_Chamados_EmpresaId_FuncionalidadeId")
  @@index([empresaId, atualizadoEm], map: "IX_Chamados_EmpresaId_AtualizadoEm")
  @@index([empresaId, slaStatus], map: "IX_Chamados_EmpresaId_SlaStatus")
  @@index([empresaId, resolucaoLimiteEm], map: "IX_Chamados_EmpresaId_ResolucaoLimiteEm")
  @@map("Chamados")
}


model ChamadoAcompanhante {
  id             String   @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  chamadoId      String   @db.UniqueIdentifier @map("ChamadoId")
  empresaId       Int      @map("EmpresaId")
  usuarioId       String   @db.UniqueIdentifier @map("UsuarioId")
  adicionadoPorId String?  @db.UniqueIdentifier @map("AdicionadoPorId")
  ativo           Boolean  @default(true) @map("Ativo")
  criadoEm        DateTime @default(now()) @map("CriadoEm")
  atualizadoEm    DateTime @updatedAt @map("AtualizadoEm")

  chamado       Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  empresa       Empresa @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario       Usuario @relation("ChamadoAcompanhanteUsuario", fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adicionadoPor Usuario? @relation("ChamadoAcompanhanteAdicionadoPor", fields: [adicionadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([chamadoId, usuarioId], map: "UX_ChamadoAcompanhantes_ChamadoId_UsuarioId")
  @@index([empresaId, chamadoId, ativo], map: "IX_ChamadoAcompanhantes_EmpresaId_ChamadoId_Ativo")
  @@index([empresaId, usuarioId, ativo], map: "IX_ChamadoAcompanhantes_EmpresaId_UsuarioId_Ativo")
  @@map("ChamadoAcompanhantes")
}
model ChamadoMensagem {
  id        String   @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  chamadoId String   @db.UniqueIdentifier @map("ChamadoId")
  empresaId Int      @map("EmpresaId")
  autorId   String   @db.UniqueIdentifier @map("AutorId")
  tipo      String   @default("PUBLICA") @map("Tipo")
  conteudo  String   @map("Conteudo")
  criadoEm  DateTime @default(now()) @map("CriadoEm")

  chamado Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  autor Usuario @relation(fields: [autorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  anexos ChamadoAnexo[]

  @@index([empresaId, chamadoId, criadoEm], map: "IX_ChamadoMensagens_EmpresaId_ChamadoId_CriadoEm")
  @@map("ChamadoMensagens")
}


model ChamadoAnexo {
  id           String   @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  chamadoId    String   @db.UniqueIdentifier @map("ChamadoId")
  empresaId    Int      @map("EmpresaId")
  autorId      String   @db.UniqueIdentifier @map("AutorId")
  mensagemId   String?  @db.UniqueIdentifier @map("MensagemId")
  nomeOriginal String   @map("NomeOriginal")
  nomeArquivo  String   @map("NomeArquivo")
  caminho      String   @map("Caminho")
  mimeType     String   @map("MimeType")
  tamanho      Int      @map("Tamanho")
  criadoEm     DateTime @default(now()) @map("CriadoEm")

  chamado Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  autor Usuario @relation(fields: [autorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mensagem ChamadoMensagem? @relation(fields: [mensagemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([empresaId, chamadoId, criadoEm], map: "IX_ChamadoAnexos_EmpresaId_ChamadoId_CriadoEm")
  @@index([empresaId, mensagemId], map: "IX_ChamadoAnexos_EmpresaId_MensagemId")
  @@index([autorId], map: "IX_ChamadoAnexos_AutorId")
  @@map("ChamadoAnexos")
}
model ChamadoHistorico {
  id            String   @id @default(uuid()) @db.UniqueIdentifier @map("Id")
  chamadoId     String   @db.UniqueIdentifier @map("ChamadoId")
  empresaId     Int      @map("EmpresaId")
  usuarioId     String?  @db.UniqueIdentifier @map("UsuarioId")
  evento        String   @map("Evento")
  campo         String?  @map("Campo")
  valorAnterior String?  @map("ValorAnterior")
  valorNovo     String?  @map("ValorNovo")
  observacao    String?  @map("Observacao")
  criadoEm      DateTime @default(now()) @map("CriadoEm")

  chamado Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([empresaId, chamadoId, criadoEm], map: "IX_ChamadoHistorico_EmpresaId_ChamadoId_CriadoEm")
  @@map("ChamadoHistorico")
}

model ChamadoCategoria {
  id          Int      @id @default(autoincrement()) @map("Id")
  empresaId   Int      @map("EmpresaId")
  nome        String   @map("Nome")
  descricao   String?  @map("Descricao")
  ativo       Boolean  @default(true) @map("Ativo")
  criadoEm    DateTime @default(now()) @map("CriadoEm")
  atualizadoEm DateTime @updatedAt @map("AtualizadoEm")

