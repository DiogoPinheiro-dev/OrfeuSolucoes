# .gitignore gerado para um projeto "client" web/Node (padrões de mercado atuais)

# Dependências
node_modules/
.pnp/
.pnp.js

# Build / outputs
dist/
build/
out/
.next/
.nuxt/
/.vercel/
/.parcel-cache/
.cache/
.web-build/
storybook-static/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ambiente / segredos
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Sistema operacional
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
.vscode/*

# TypeScript / compilador
*.tsbuildinfo
*.js.map
*.d.ts.map

# Testes / cobertura
coverage/
.nyc_output/
jest-*.json
cypress/screenshots/
cypress/videos/

# Cache de ferramentas
.cache/
dist-ssr/
.sass-cache
.next/cache

# Ferramentas de empacotamento / workspace
.yarn/*
.yarnrc.yml
.yarn-integrity
.yarn-release
.pnpm-store/
pnpm-lock.yaml
# OBS: mantenha yarn.lock / package-lock.json se desejar travar versões

# CI / deploy / runtime
.envrc
.serverless/
.now/
.vercel/
firebase-debug.log

# Outros
*.local
*.swp
*.swo
*.tmp

# Logs de IDE/OS e metadados específicos
*.DS_Store
*.applesingle
Icon?
Desktop.ini

# Final: exceções úteis (mantém exemplos)
!.env.example